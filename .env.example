# ─── Meta API Erişim ───────────────────────────────────────────
META_ACCESS_TOKEN=your_meta_access_token_here
META_API_VERSION=v21.0
META_DATE_PRESET=last_7d

# ─── Reklam Hesapları ───────────────────────────────────────────
# Virgülle ayrılmış çoklu hesap
META_AD_ACCOUNT_IDS=act_1234567890,act_0987654321

# Essenceoflife hesabı (track/recommend/create komutları bu hesabı kullanır)
ESSENCE_AD_ACCOUNT_ID=act_461218213196078
ESSENCE_PAGE_ID=your_page_id_here
ESSENCE_INSTAGRAM_ID=your_instagram_actor_id_here
ESSENCE_PIXEL_ID=your_pixel_id_here

# İlgi alanı ID'leri (search-interests.js ile bulunur)
# Örnek: node search-interests.js "kadın giyim"
ESSENCE_INTEREST_IDS=

# Geriye uyumluluk — tek hesap varsa:
# META_AD_ACCOUNT_ID=act_1234567890

# ─── Hedefleme ──────────────────────────────────────────────────
# Preset seçenekleri: turkiye | avrupa_turk | avrupa_toptan | korfez | global_test
DEFAULT_TARGETING_PRESET=turkiye

# Özel ülkeler (ayarlanırsa DEFAULT_TARGETING_PRESET'i geçersiz kılar)
# TARGET_COUNTRIES=TR,DE,NL

DEFAULT_AGE_MIN=24
DEFAULT_AGE_MAX=50

# Varsayılan günlük bütçe (kuruş — 5000 = 50 TL)
DEFAULT_DAILY_BUDGET=5000

# ─── Güvenlik ───────────────────────────────────────────────────
# SAFE_MODE=true  → Bütçe değişikliği engellenir (varsayılan)
# SAFE_MODE=false → apply-budget komutu bütçe değiştirebilir
SAFE_MODE=true

# Maksimum günlük bütçe limiti (kuruş — 0 = sınır yok)
# 50000 = 500 TL limit
MAX_DAILY_BUDGET=0

# ─── Performans Eşikleri ─────────────────────────────────────────
LOW_CTR=1
HIGH_CPC=5
HIGH_ROAS=3
LOW_CPA=50
HIGH_SPEND_NO_PURCHASE=100
MIN_DATA_SPEND=20
