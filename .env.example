OPENAI_API_KEY=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=

# Agent'ın birincil modeli (LiteLLM formatı). Varsayılan: ücretsiz Google Gemini.
PRIMARY_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
# Görsel analizi için kullanılan vision modeli (opsiyonel).
# VISION_MODEL=gemini/gemini-2.5-flash

# Birincil model kota/limit hatası verirse devreye giren yedek model (virgülle
# ayrılmış zincir; bir model dolar/hata verirse otomatik sıradakine geçilir).
# "openai" = agent'ın yerleşik OpenAI modeli. Claude için: anthropic/claude-opus-4-8
FALLBACK_MODEL=gemini/gemini-flash-latest,gemini/gemini-2.5-pro,openai
# ANTHROPIC_API_KEY=
# Opsiyonel sağlayıcılar (LiteLLM): istediğin modeli zincire ekleyip anahtarını tanımla.
#  - OpenRouter (çok modelli, ücretsiz seçenekler dahil): model 'openrouter/...'
#    Ücretsiz + araç çağırabilen örnek: openrouter/openai/gpt-oss-120b:free
# OPENROUTER_API_KEY=
#  - Groq (hızlı): 'groq/llama-3.3-70b-versatile'
# GROQ_API_KEY=

# Günlük e-posta raporu (app/send_report.py) için Gmail SMTP ayarları (opsiyonel).
# SMTP_PASSWORD = Google "Uygulama Şifresi" (normal şifre değil, 2FA gerekli).
SMTP_USER=
SMTP_PASSWORD=
REPORT_TO=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Operatör modu (yazma işlemleri). Varsayılan KAPALI — gerçek hesabı değiştirir.
# Açmak için 'true' yap; Meta token'ı ads_management iznine sahip olmalı.
ENABLE_WRITE_ACTIONS=false

# Güvenlik tavanı: tek bir reklam seti/kampanyaya atanabilecek azami günlük
# bütçe (TL). Yazım hatalarını (3.000 yerine 300.000) ve hatalı kararları yakalar.
# Tanımlanmazsa varsayılan 50000.
# MAX_DAILY_BUDGET_TRY=50000
