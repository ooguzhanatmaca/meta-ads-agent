OPENAI_API_KEY=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_GRAPH_API_VERSION=

# Agent'ın birincil modeli (LiteLLM formatı). Varsayılan: ücretsiz Google Gemini.
PRIMARY_MODEL=gemini/gemini-2.0-flash
GEMINI_API_KEY=
# Görsel analizi için kullanılan vision modeli (opsiyonel).
# VISION_MODEL=gemini/gemini-2.0-flash

# Birincil model kota/limit hatası verirse devreye giren yedek model.
# "openai" = agent'ın yerleşik OpenAI modeli. Claude için: anthropic/claude-opus-4-8
FALLBACK_MODEL=gemini/gemini-2.5-flash,gemini/gemini-2.0-flash-lite,gemini/gemini-2.5-pro,groq/llama-3.3-70b-versatile,openai
# ANTHROPIC_API_KEY=
# Groq (ücretsiz, hızlı Llama) için: console.groq.com
GROQ_API_KEY=

# Günlük e-posta raporu (app/send_report.py) için Gmail SMTP ayarları (opsiyonel).
# SMTP_PASSWORD = Google "Uygulama Şifresi" (normal şifre değil, 2FA gerekli).
SMTP_USER=
SMTP_PASSWORD=
REPORT_TO=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
